# ==========================================
# 🚒 MS-EMERGENCIAS - Variables de Entorno
# ==========================================
# Copia este archivo a .env y personaliza

# Puerto del servicio
PORT=3006

# Node environment
NODE_ENV=development

# Base de datos PostgreSQL (Docker)
DB_USER=fococero_admin
DB_PASSWORD=change-me-db-password
DB_HOST=db-fococero
DB_PORT=5432
DB_NAME=emergencias_db

# Base de datos PostgreSQL (Local)
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=5433

# Eureka Service Discovery
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_CLIENT_REGISTERWITHEUREKA=true
EUREKA_CLIENT_FETCHREGISTRY=true
EUREKA_INSTANCE_PORT=3006

# Seguridad interna
INTERNAL_SECRET_TOKEN=change-me-internal-token
API_GATEWAY_URL=http://api-gateway:3000

# Webhooks externos (emergencias)
BOMBEROS_API_URL=https://api.bomberos.cl
BOMBEROS_API_KEY=change-me-bomberos-key
CONAF_API_URL=https://api.conaf.cl
CONAF_API_KEY=change-me-conaf-key
CARABINEROS_API_URL=https://api.carabineros.cl
CARABINEROS_API_KEY=change-me-carabineros-key
SENAPRED_API_URL=https://api.senapred.cl
SENAPRED_API_KEY=change-me-senapred-key

# Resiliencia
MAX_RETRIES=3
RETRY_DELAY_MS=2000
AXIOS_TIMEOUT_MS=5000
